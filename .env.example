# Database Configuration
DB_HOST=localhost
DB_NAME=pixco
DB_USER=root
DB_PASS=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_PORT=587
SMTP_FROM_EMAIL=noreply@pixco.com
SMTP_FROM_NAME=Pixco

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://yourdomain.com/google-login.php

# Site Configuration
SITE_NAME=Pixco
DEFAULT_LANGUAGE=id

# Security
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict